node_modules/
.DS_Store

# Generated cache and manifest files
.cache/
.codicil-manifest.json
.codicil-manifest.msgpack
*.db
*.db-journal
.archive/

# Neural memory (regenerate with: node scripts/neural-memory.js build)
.neural/

# Generated artifacts
index.json
index.json.backup
slim-context.json
graph.html
graph-codicil.html

# Claude Code session locks
.claude/*.lock
.claude/settings.local.json

# Schemas (generated from source)
schemas/session.schema.msgpack

# Private project summaries/metadata (only Codicil is public)
summaries/projects/*
!summaries/projects/Codicil/

# Session logs (use examples/sessions/ for curated demos)
summaries/projects/*/sessions/*.json
metadata/projects/*
!metadata/projects/Codicil.json
!metadata/projects/Codicil.msgpack

# Private templates
templates/AGENTS-*.md

.memex-manifest.*
