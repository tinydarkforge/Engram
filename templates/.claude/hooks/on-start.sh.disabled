#!/bin/bash
# Auto-load Codicil on Claude startup

CODICIL_PATH="${CODICIL_PATH:-$HOME/code/cirrus/DevOps/Codicil}"

# Check if Codicil exists
if [ ! -d "$CODICIL_PATH" ]; then
  echo "⚠️  Codicil not found at $CODICIL_PATH"
  exit 0
fi

# Load Codicil context
echo "🧠 Loading Codicil..."
node "$CODICIL_PATH/scripts/codicil-loader.js" startup

# Sync latest knowledge (background, non-blocking)
(cd "$CODICIL_PATH" && git pull --quiet origin main 2>/dev/null &)
