[Unit]
Description=Engram MCP HTTP Server
After=network.target

[Service]
Type=simple
User=engram
Group=engram
WorkingDirectory=/opt/engram
EnvironmentFile=/etc/engram/engram.env
ExecStart=/usr/bin/node /opt/engram/scripts/mcp-server-http.mjs
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/engram

[Install]
WantedBy=multi-user.target

