#!/usr/bin/env node

/**
 * Remember - Smart wrapper for save-session.js
 *
 * Usage:
 *   codicil                          # Auto-capture from git changes
 *   remember "what you did"        # Quick with auto-topics
 *   learn "summary" --topics a,b   # Full control
 *   remember --interactive         # Prompts for everything
 */

const { execFileSync } = require('child_process');
const path = require('path');
const fs = require('fs');
const { resolveCodicilPath } = require('./paths');
const { readJSON } = require('./safe-json');

const CODICIL_PATH = resolveCodicilPath(__dirname);
const SAVE_SESSION = path.join(__dirname, 'save-session.js');

/**
 * Check if we should update recent session instead of creating new one
 */
function shouldUpdateRecent(topics, files) {
  try {
    // Detect current project
    const Codicil = require(path.join(CODICIL_PATH, 'scripts', 'codicil-loader.js'));
    const codicil = new Codicil();
    codicil.loadIndex();
    const detection = codicil.detectProject();

    if (!detection.project) return null;

    // Load sessions index
    const sessionsPath = path.join(CODICIL_PATH, 'summaries', 'projects', detection.project, 'sessions-index.json');
    if (!fs.existsSync(sessionsPath)) return null;

    const sessionsData = readJSON(sessionsPath);
    if (!sessionsData || !sessionsData.sessions || sessionsData.sessions.length === 0) return null;

    // Get most recent session
    const recent = sessionsData.sessions[0]; // Already sorted by date

    // Check if it's from today
    const today = new Date().toISOString().split('T')[0];
    if (recent.date !== today) return null;

    // Calculate topic overlap
    const recentTopics = new Set(recent.topics || []);
    const overlap = Array.from(topics).filter(t => recentTopics.has(t)).length;
    const similarity = topics.size > 0 ? overlap / topics.size : 0;

    // If >60% topic overlap, suggest update
    if (similarity > 0.6) {
      return {
        id: recent.id,
        summary: recent.summary,
        topics: recent.topics,
        similarity: Math.round(similarity * 100)
      };
    }

    return null;
  } catch (e) {
    return null;
  }
}

/**
 * Auto-detect what changed and generate summary
 */
function autoCapture() {
  try {
    // Check git status
    const status = execFileSync('git', ['status', '--short'], { encoding: 'utf8' }).trim();

    if (!status) {
      console.log('📭 No changes detected to capture.');
      console.log('💡 Make some changes first, or use: codicil --interactive');
      process.exit(0);
    }

    // Get changed files
    const files = status.split('\n').map(line => {
      const match = line.match(/^\s*[MADRCU?]+\s+(.+)$/);
      return match ? match[1] : null;
    }).filter(Boolean);

    // Get git diff summary
    let diffSummary = '';
    try {
      diffSummary = execFileSync('git', ['diff', '--stat', 'HEAD'], { encoding: 'utf8' }).trim();
    } catch (e) {
      // Might be untracked files
      diffSummary = `${files.length} files changed`;
    }

    // Extract topics from file paths
    const topics = new Set();
    files.forEach(file => {
      const parts = file.toLowerCase().split(/[\/\.\-_]/);
      parts.forEach(part => {
        // Filter meaningful words (3+ chars, not common dirs)
        if (part.length >= 3 &&
            !['src', 'lib', 'test', 'spec', 'index', 'main', 'app'].includes(part) &&
            !part.match(/^\d+$/) &&
            !['tsx', 'jsx', 'ts', 'js', 'json', 'md', 'css', 'scss'].includes(part)) {
          topics.add(part);
        }
      });
    });

    // Generate summary
    const topFiles = files.slice(0, 3).map(f => path.basename(f)).join(', ');
    const moreFiles = files.length > 3 ? ` +${files.length - 3} more` : '';
    const summary = `Updated ${topFiles}${moreFiles}`;

    // Check for recent similar session
    const recentSession = shouldUpdateRecent(topics, files);

    if (recentSession) {
      console.log(`🔄 Found similar recent session from today:`);
      console.log(`   ID: ${recentSession.id}`);
      console.log(`   Summary: "${recentSession.summary}"`);
      console.log(`   Similarity: ${recentSession.similarity}%`);
      console.log('');
      console.log('✅ Skipping - already captured similar work today');
      console.log('💡 To force new session: codicil "your summary"');
      console.log('💡 To add more: codicil --interactive');
      process.exit(0);
    }

    // Show what we detected
    console.log('🔍 Auto-detected changes:');
    console.log(`   Files: ${files.length}`);
    console.log(`   Summary: "${summary}"`);
    console.log(`   Topics: ${Array.from(topics).slice(0, 5).join(', ') || 'none detected'}`);
    console.log('');

    // Build command
    const cmdArgs = [SAVE_SESSION, summary];
    if (topics.size > 0) {
      cmdArgs.push('--topics', Array.from(topics).slice(0, 8).join(','));
    }

    // Execute
    execFileSync(process.execPath, cmdArgs, {
      stdio: 'inherit',
      cwd: process.cwd()
    });

  } catch (error) {
    console.error('❌ Auto-capture failed:', error.message);
    console.log('💡 Try: codicil --interactive');
    process.exit(1);
  }
}

/**
 * Smart mode: auto-detect topics if not provided
 */
function smartCapture(summary) {
  // Check if topics already provided
  const hasTopics = process.argv.some(arg => arg.startsWith('--topics'));

  if (hasTopics) {
    // User provided topics, pass through
    execFileSync(process.execPath, [SAVE_SESSION, ...process.argv.slice(2)], {
      stdio: 'inherit',
      cwd: process.cwd()
    });
    return;
  }

  // Auto-generate topics from summary
  const topics = new Set();
  const words = summary.toLowerCase().split(/\s+/);

  // Extract meaningful words
  const stopWords = ['a', 'an', 'the', 'and', 'or', 'but', 'in', 'on', 'at', 'to', 'for', 'of', 'with'];
  words.forEach(word => {
    const clean = word.replace(/[^a-z0-9]/g, '');
    if (clean.length >= 3 && !stopWords.includes(clean)) {
      topics.add(clean);
    }
  });

  // Get git context for more topics
  try {
    const files = execFileSync('git', ['status', '--short'], { encoding: 'utf8' })
      .trim()
      .split('\n')
      .map(line => line.replace(/^\s*[MADRCU?]+\s+/, ''))
      .filter(Boolean);

    files.forEach(file => {
      const parts = file.toLowerCase().split(/[\/\.\-_]/);
      parts.forEach(part => {
        if (part.length >= 3 &&
            !['src', 'lib', 'test', 'index'].includes(part) &&
            !part.match(/^(tsx?|jsx?|json|md|css)$/)) {
          topics.add(part);
        }
      });
    });
  } catch (e) {
    // Ignore git errors
  }

  const topicsList = Array.from(topics).slice(0, 8).join(',');
  const topicsArg = topicsList ? `--topics ${topicsList}` : '';

  console.log(`💡 Auto-detected topics: ${topicsList || 'none'}\n`);

  const cmdArgs = [SAVE_SESSION, summary];
  if (topicsList) {
    cmdArgs.push('--topics', topicsList);
  }
  execFileSync(process.execPath, cmdArgs, {
    stdio: 'inherit',
    cwd: process.cwd()
  });
}

/**
 * #36: Git Hook Auto-Capture Mode
 * Called from post-commit hook with environment variables
 */
function gitHookAutoCapture() {
  const summary = process.env.CODICIL_SUMMARY;
  const topics = process.env.CODICIL_TOPICS;
  const commit = process.env.CODICIL_COMMIT;
  const linesAdded = process.env.CODICIL_LINES_ADDED || '0';
  const linesRemoved = process.env.CODICIL_LINES_REMOVED || '0';

  if (!summary) {
    console.log('⚠️  No summary provided in CODICIL_SUMMARY');
    return;
  }

  console.log('📝 Auto-capturing session from git hook');
  console.log(`   Summary: ${summary}`);
  console.log(`   Topics: ${topics || 'auto-detected'}`);
  console.log(`   Commit: ${commit?.substring(0, 7) || 'unknown'}`);
  console.log(`   Changes: +${linesAdded}/-${linesRemoved}`);

  const cmdArgs = [SAVE_SESSION, summary];
  if (topics) {
    cmdArgs.push('--topics', topics);
  }
  // Git hook captures should commit since they're triggered by a commit
  cmdArgs.push('--commit');

  try {
    execFileSync(process.execPath, cmdArgs, {
      stdio: 'inherit',
      cwd: process.cwd()
    });
    console.log('✅ Session auto-captured successfully');
  } catch (error) {
    console.log('⚠️  Session capture failed (non-fatal)');
  }
}

// Main logic
const args = process.argv.slice(2);

try {
  // #36: Check for git hook auto-capture mode
  if (args[0] === '--auto' || process.env.CODICIL_AUTO_CAPTURE) {
    gitHookAutoCapture();
  } else if (args.length === 0) {
    // Zero parameters: auto-capture everything
    autoCapture();
  } else if (args[0] === '--interactive' || args[0] === '-i') {
    // Interactive mode
    execFileSync(process.execPath, [SAVE_SESSION, ...args], {
      stdio: 'inherit',
      cwd: process.cwd()
    });
  } else if (!args.some(arg => arg.startsWith('--topics'))) {
    // Has summary but no topics: smart mode
    smartCapture(args[0]);
  } else {
    // Full control: pass through
    execFileSync(process.execPath, [SAVE_SESSION, ...args], {
      stdio: 'inherit',
      cwd: process.cwd()
    });
  }
} catch (error) {
  process.exit(error.status || 1);
}
