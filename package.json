{
  "name": "codicil",
  "version": "4.0.0",
  "description": "Persistent memory for AI coding assistants - 94-98% token savings",
  "main": "scripts/codicil-loader.js",
  "scripts": {
    "start": "node scripts/server.js",
    "startup": "node scripts/codicil-loader.js startup",
    "test": "node --test tests/*.test.js",
    "status": "node scripts/codicil-loader.js status",
    "setup": "node scripts/setup.js",
    "migrate": "node scripts/migrate.js",
    "metrics:backfill": "node scripts/metrics-backfill.js",
    "mcp:http": "node scripts/mcp-server-http.mjs",
    "search": "node scripts/codicil-loader.js search",
    "semantic": "node scripts/codicil-loader.js semantic",
    "manifest": "node scripts/manifest-manager.js generate",
    "bloom:build": "node scripts/bloom-filter.js build",
    "bloom:stats": "node scripts/bloom-filter.js stats",
    "lazy:convert": "node scripts/lazy-loader.js convert",
    "lazy:stats": "node scripts/lazy-loader.js stats",
    "git:index": "node scripts/index-git.js build",
    "git:query": "node scripts/index-git.js query",
    "semantic:stats": "node scripts/vector-search.js stats",
    "ledger:migrate": "node scripts/migrations.js",
    "ledger:stats": "node -e \"const l = require('./scripts/ledger'); if (l.stats) console.log(JSON.stringify(l.stats(), null, 2)); else console.log('ledger not yet implemented');\""
  },
  "keywords": [
    "codicil",
    "memory",
    "knowledge-base",
    "mcp",
    "agent",
    "ai",
    "context",
    "semantic-search"
  ],
  "author": "TinyDarkForge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pamperito74/Codicil.git"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "better-sqlite3": "^9.2.2",
    "chalk": "^4.1.2",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "msgpack-lite": "^0.1.26"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
