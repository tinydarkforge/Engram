{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Assertion",
  "description": "A claim with lineage, confidence, decay class, and authority plane",
  "type": "object",
  "required": ["id", "plane", "class", "claim", "confidence", "status", "created_at", "staleness_model"],
  "properties": {
    "id": { "type": "string", "pattern": "^a_[0-9]+_[a-f0-9]{6}$" },
    "plane": { "type": "string", "description": "e.g. user:daniel, project:Memex, session:<id>" },
    "class": { "type": "string", "enum": ["monotonic", "episodic", "state_bound", "contextual"] },
    "claim": { "type": "string", "minLength": 1, "maxLength": 500 },
    "body": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "quorum_count": { "type": "integer", "minimum": 1 },
    "status": { "type": "string", "enum": ["tentative", "established", "fossilized", "quarantined"] },
    "created_at": { "type": "string", "format": "date-time" },
    "last_reinforced": { "type": ["string", "null"], "format": "date-time" },
    "last_verified": { "type": ["string", "null"], "format": "date-time" },
    "staleness_model": { "type": "string", "enum": ["flat", "exponential", "episodic", "state_bound", "contextual"] },
    "cache_stable": { "type": "integer", "enum": [0, 1] },
    "density_hint": { "type": "string", "enum": ["terse", "standard", "verbose"] }
  }
}
